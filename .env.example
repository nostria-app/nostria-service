# Environment variables
NODE_ENV=development
PORT=3000

# Web Push configuration
PUBLIC_VAPID_KEY=your_public_vapid_key_here
PRIVATE_VAPID_KEY=your_private_vapid_key_here
VAPID_SUBJECT=mailto:your-email@example.com

# For managed identity (recommended for production)
# AZURE_TENANT_ID=your_tenant_id
# AZURE_CLIENT_ID=your_client_id
# Note: Settings are automatically stored in a separate "settings" table

# Azure CosmosDB (for backup jobs)
AZURE_COSMOSDB_CONNECTION_STRING=your_cosmosdb_connection_string_here
# For managed identity (recommended for production)
# AZURE_COSMOSDB_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOSDB_DATABASE_NAME=NostriaDB
AZURE_COSMOSDB_CONTAINER_NAME=Documents

# API Security
SERVICE_API_KEY=your_generated_guid_here

# Admin Configuration
# Comma-separated list of public keys that have admin access to list endpoints
ADMIN_PUBKEYS=admin_pubkey_1_here,admin_pubkey_2_here

# Automatically set payment as paid after 10 sseconds

# Notification limits
FREE_TIER_DAILY_LIMIT=5
PREMIUM_TIER_DAILY_LIMIT=50

# Logging
LOG_LEVEL=info

# xAI / Grok
# Required to enable Nostria-hosted Grok requests through nostria-service.
XAI_API_KEY=your_xai_api_key_here
# Optional override. Leave as-is for the standard xAI API.
XAI_BASE_URL=https://api.x.ai/v1

# PostgreSQL Configuration
# Choose one of the following formats based on your setup:

# Local Development
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/nostria"

# Azure Database for PostgreSQL
# DATABASE_URL="postgresql://yourusername@yourserver:yourpassword@yourserver.postgres.database.azure.com:5432/nostria?sslmode=require"

# AWS RDS PostgreSQL
# DATABASE_URL="postgresql://username:password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/nostria"

# Google Cloud SQL
# DATABASE_URL="postgresql://username:password@your-cloud-sql-ip:5432/nostria"

# Migration Feature Flags
USE_POSTGRESQL=false              # Set to true to use PostgreSQL as primary
DUAL_DATABASE_MODE=true           # Enable both databases during migration
MIGRATION_MODE=true               # Enable migration utilities

# Test Database (optional)
TEST_DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/nostria_test"

# Nostr Zap Configuration
# Comma-separated list of relay URLs to listen for zap receipts
NOSTR_ZAP_RELAYS="wss://ribo.eu.nostria.app,wss://ribo.af.nostria.app,wss://ribo.us.nostria.app,wss://relay.damus.io,wss://relay.primal.net"

# X Dual-posting
# Set the callback URL in the X developer portal to your public API callback endpoint.
X_CONSUMER_KEY=your_x_consumer_key_here
X_CONSUMER_SECRET=your_x_consumer_secret_here
X_CALLBACK_URL=https://api.nostria.app/api/x/callback
# Used for redirecting users back into Nostria after X authorization.
NOSTRIA_APP_URL=https://nostria.app/
# Generate a long random secret for encrypting stored X access tokens.
X_TOKEN_ENCRYPTION_SECRET=replace_with_a_long_random_secret
# Optional safety cap. Set to 0 to disable rate limiting by 24h usage.
X_MAX_POSTS_PER_24H=12

# Private key for "Nostria Premium" account to post gift notifications
# Can be in hex format or nsec format
# Generate with: npx nostr-tools generate-key
NOSTR_PREMIUM_NOTIFICATION_PRIVATE_KEY=your_private_key_hex_or_nsec_here

# Nostr Wallet Connect for admin-initiated investor payouts
# Format: nostr+walletconnect://<wallet_pubkey>?relay=wss://relay.example&secret=<hex_secret>
NOSTRIA_NWC_CONNECTION_STRING=
NOSTRIA_NWC_TIMEOUT_MS=30000
