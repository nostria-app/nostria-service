# Environment variables
NODE_ENV=development
PORT=3000

# Azure Table Storage
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
# For managed identity (recommended for production)
# AZURE_TENANT_ID=your_tenant_id
# AZURE_CLIENT_ID=your_client_id
TABLE_NAME=accounts
SUBSCRIPTIONS_TABLE_NAME=subscriptions
PAYMENTS_TABLE_NAME=payments
ADMIN_AUDIT_TABLE_NAME=adminaudit
SUBSCRIPTION_HISTORY_TABLE_NAME=subscriptionhistory
USER_ACTIVITY_TABLE_NAME=useractivity

# API Security
SERVICE_API_KEY=your_generated_guid_here

# Admin accounts (comma-separated public keys)
ADMIN_PUBKEYS=npub1admin1example,npub1admin2example,npub1admin3example

# Subscription settings
FREE_TIER_DAILY_LIMIT=5
PREMIUM_TIER_DAILY_LIMIT=50
PREMIUM_PLUS_TIER_DAILY_LIMIT=500

# Subscription pricing (in cents to avoid floating point issues)
PREMIUM_MONTHLY_PRICE=999
PREMIUM_QUARTERLY_PRICE=2497
PREMIUM_YEARLY_PRICE=9999
PREMIUM_PLUS_MONTHLY_PRICE=1999
PREMIUM_PLUS_QUARTERLY_PRICE=4997
PREMIUM_PLUS_YEARLY_PRICE=19999

# Logging
LOG_LEVEL=info
